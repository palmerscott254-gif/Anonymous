NODE_ENV=development
PORT=3001

# Backend settings
DATABASE_URL=
CORS_ORIGIN=http://localhost:5173,capacitor://localhost,ionic://localhost
JWT_SECRET=change-this-to-a-long-random-secret-value-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
ROOM_TTL_DEFAULT_MINUTES=10
ROOM_TTL_MAX_MINUTES=1440
HTTP_RATE_LIMIT_PER_MIN=180
SOCKET_RATE_LIMIT_PER_MIN=180

# Frontend backend endpoints
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# Optional Android emulator or LAN host override for local testing
VITE_ANDROID_HOST=10.0.2.2NODE_ENV=development
PORT=3001
DATABASE_URL=
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,capacitor://localhost,ionic://localhost
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
ROOM_TTL_DEFAULT_MINUTES=10
ROOM_TTL_MAX_MINUTES=1440
HTTP_RATE_LIMIT_PER_MIN=180
SOCKET_RATE_LIMIT_PER_MIN=180

VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_ANDROID_HOST=# Backend runtime
NODE_ENV=development
PORT=3001

# Frontend allowed origins (comma-separated in production)
CORS_ORIGIN=http://localhost:5173

# JWT auth configuration
JWT_SECRET=change-this-to-a-long-random-secret-value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Room/session defaults
ROOM_TTL_DEFAULT_MINUTES=10
ROOM_TTL_MAX_MINUTES=1440

# HTTP/socket rate limits
HTTP_RATE_LIMIT_PER_MIN=1200
SOCKET_RATE_LIMIT_PER_MIN=360

# PostgreSQL (URL-encoded if password/db name includes special characters/spaces)
# Example for password <254admin020> and db "Ghost Chats":
# DATABASE_URL=postgresql://postgres:%3C254admin020%3E@localhost:5432/Ghost%20Chats
DATABASE_URL=

# Frontend socket URL
# For web development: http://localhost:3001
# For Android: http://YOUR_MACHINE_IP:3001
VITE_SOCKET_URL=http://localhost:3001
