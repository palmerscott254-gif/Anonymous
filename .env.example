# Backend runtime
NODE_ENV=development
PORT=3001

# PostgreSQL (URL-encoded if password/db name includes special characters/spaces)
# Example for password <254admin020> and db "Ghost Chats":
# DATABASE_URL=postgresql://postgres:%3C254admin020%3E@localhost:5432/Ghost%20Chats
DATABASE_URL=

# Frontend socket URL
# For web development: http://localhost:3001
# For Android: http://YOUR_MACHINE_IP:3001
VITE_SOCKET_URL=http://localhost:3001
